# Public routing
TRAEFIK_HOST=studio.seudominio.com

# Generate an htpasswd-compatible hash and escape $ as $$ before pasting.
TRAEFIK_BASIC_AUTH_USERS=studio:$$apr1$$replace_me$$replace_me

# Core integrations
HF_API_KEY=
HF_API_SECRET=
OPENAI_API_KEY=
OPENAI_PLANNER_MODEL=gpt-5.4-pro
ELEVENLABS_API_KEY=

# Optional Google Drive upload
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_DRIVE_FOLDER_ID=
# GOOGLE_SERVICE_ACCOUNT_HOST_PATH=/opt/jose-wipes/credentials/service-account.json

# Runtime defaults
TZ=America/Sao_Paulo
PYTHONUNBUFFERED=1
